# Ejemplo de variables de entorno para CrediExpress
# Copia este archivo a `.env` y completa los valores según tu entorno.

# Credenciales de cédula solo para desarrollo local con `npm run dev`
# En produccion no uses variables `VITE_` para estas credenciales.
VITE_CEDULA_API_USER=
VITE_CEDULA_API_PASSWORD=

# Variables del proxy serverless (Vercel / vercel dev)
ORIGINARSA_API_BASE_URL=https://api-pre.originarsa.com/api
CEDULA_API_USER=
CEDULA_API_PASSWORD=

# Firebase Configuration
# Obtén estos valores desde la consola de Firebase (Project Settings > General > Your apps)

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Ejemplo de valores Firebase (no uses estos en producción):
# VITE_FIREBASE_API_KEY=AIzaSyC_example_key_123456789
# VITE_FIREBASE_AUTH_DOMAIN=crediexpress-123.firebaseapp.com  
# VITE_FIREBASE_PROJECT_ID=crediexpress-123
# VITE_FIREBASE_STORAGE_BUCKET=crediexpress-123.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
# VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef123456789
